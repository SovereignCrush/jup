#!/usr/bin/env node

const { randomUUID } = require("node:crypto");
const { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } = require("node:fs");
const { join, resolve } = require("node:path");

const PACKAGE_JSON = JSON.parse(readFileSync(resolve(__dirname, "..", "package.json"), "utf8"));

const DEFAULT_POLICY = {
  maxAutoSettleUSDC: 5,
  maxAllowedSettleUSDC: 100,
  maxPriceImpactBps: 100,
  reviewHighPriceImpact: true,
  verifiedTokens: ["USDC", "SOL", "JUP", "BONK"],
  trustedRecipients: [],
  reviewUnknownRecipients: true,
};

const DEFAULT_CONFIG = {
  reviewBaseUrl: "https://www.jup.sh",
  policyPath: "jup.policy.json",
  intentStore: ".jup-sh/intents",
  quoteProvider: "mock",
  intentTtlMinutes: 15,
  quoteTtlMinutes: 2,
};

const MOCK_PRICES_USDC = {
  USDC: 1,
  SOL: 150,
  JUP: 1.2,
  BONK: 0.00002,
};

const TOKENS = {
  SOL: {
    mint: "So11111111111111111111111111111111111111112",
    decimals: 9,
  },
  USDC: {
    mint: "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
    decimals: 6,
  },
  JUP: {
    mint: "JUPyiwrYJFskUPiHa7hkeR8VUtAeFoSYbKedZNsDvCN",
    decimals: 6,
  },
  BONK: {
    mint: "DezXAZ8z7PnrnRJjz3my2u6r5KiL3HR8APpPB2634B2",
    decimals: 5,
  },
};

main().catch((error) => {
  console.error(`error: ${error.message}`);
  process.exit(1);
});

async function main() {
  const [command, ...args] = process.argv.slice(2);

  if (!command || command === "--help" || command === "-h") {
    printHelp();
    return;
  }

  if (command === "pay") {
    const intent = await runPay(args);
    printIntent(intent, hasFlag(args, "json"));
    process.exit(exitCodeForDecision(intent.decision));
  }

  if (command === "init") {
    runInit(args);
    return;
  }

  if (command === "policy") {
    runPolicy(args);
    return;
  }

  if (command === "intent") {
    await runIntent(args);
    return;
  }

  if (command === "review") {
    runReview(args);
    return;
  }

  if (command === "doctor") {
    runDoctor(args);
    return;
  }

  throw new Error(`unknown command: ${command}`);
}

async function runPay(args) {
  const options = parseOptions(args);
  const config = loadConfig(options.config);
  const effectiveOptions = mergeConfigOptions(options, config);
  const policy = loadPolicy(effectiveOptions.policy);
  const { settleAmount, settleToken } = parseSettlement(options);
  const input = {
    agent: required(options.agent, "agent"),
    payToken: normalizeToken(required(options.token, "token")),
    settleAmount,
    settleToken: normalizeToken(settleToken),
    recipient: options.recipient ?? null,
    recipientTokenAccount: options.recipientTokenAccount ?? null,
    reference: options.reference ?? null,
  };

  const prePolicy = evaluatePolicy(input, policy);
  const quote =
    prePolicy.decision === "rejected"
      ? null
      : await quoteSettlement(input, effectiveOptions, policy);
  const finalResult = quote
    ? policyResultFromChecks([...prePolicy.checks, ...evaluateQuotePolicy(quote, policy)])
    : prePolicy;
  const intentId = `intent_${randomUUID().replaceAll("-", "")}`;
  const reviewBaseUrl = (effectiveOptions.reviewBaseUrl ?? DEFAULT_CONFIG.reviewBaseUrl).replace(/\/+$/, "");
  const createdAt = new Date();
  const transactionRequestToken = randomUUID().replaceAll("-", "");
  const quoteWithFreshness = quote
    ? {
        ...quote,
        capturedAt: createdAt.toISOString(),
        expiresAt: expiresAtFor(createdAt, effectiveOptions.quoteTtlMinutes).toISOString(),
      }
    : null;
  const intent = {
    intentId,
    agent: input.agent,
    payToken: input.payToken,
    recipient: input.recipient,
    recipientTokenAccount: input.recipientTokenAccount,
    reference: input.reference,
    settlement: {
      amount: input.settleAmount,
      token: input.settleToken,
    },
    quote: quoteWithFreshness,
    status: statusForDecision(finalResult.decision),
    decision: finalResult.decision,
    nextAction: finalResult.nextAction,
    riskLevel: finalResult.riskLevel,
    reasons: finalResult.reasons,
    policyChecks: finalResult.checks,
    reviewUrl: `${reviewBaseUrl}/pay/${intentId}`,
    reviewCommand: buildReviewCommand(intentId),
    transactionRequest: {
      requestToken: transactionRequestToken,
    },
    createdAt: createdAt.toISOString(),
    expiresAt: expiresAtFor(createdAt, effectiveOptions.intentTtlMinutes).toISOString(),
  };

  saveIntent(intent, effectiveOptions.store);
  return withReviewHandoff(intent, reviewBaseUrl);
}

function runInit(args) {
  const options = parseOptions(args);
  const configPath = options.config ?? "jup.config.json";
  const policyPath = options.policy ?? DEFAULT_CONFIG.policyPath;
  const config = {
    ...DEFAULT_CONFIG,
    policyPath,
  };

  assertWritable(configPath, options.force);
  assertWritable(policyPath, options.force);
  writeJsonFile(configPath, config);
  writeJsonFile(policyPath, DEFAULT_POLICY);

  const result = {
    configPath,
    policyPath,
    intentStore: config.intentStore,
    reviewBaseUrl: config.reviewBaseUrl,
  };

  if (options.json) {
    console.log(JSON.stringify(result, null, 2));
  } else {
    console.log(`wrote ${configPath}`);
    console.log(`wrote ${policyPath}`);
    console.log("");
    console.log("Next:");
    console.log("  jup-sh pay --agent deepseek --token SOL --amount 20 --settle USDC --json");
  }
}

function runPolicy(args) {
  const [subcommand, ...rest] = args;
  const options = parseOptions(rest);
  const config = loadConfig(options.config);
  const policyPath = options.policy ?? (config.loaded ? config.policyPath : "jup.policy.json");

  if (subcommand === "show") {
    const policy = loadPolicy(options.policy ?? (config.loaded ? config.policyPath : undefined));
    if (options.json) {
      console.log(JSON.stringify(policy, null, 2));
    } else {
      printPolicy(policy);
    }
    return;
  }

  if (subcommand === "init") {
    const path = options.path ?? "jup.policy.json";
    if (existsSync(path) && !options.force) {
      throw new Error(`${path} already exists; pass --force to overwrite`);
    }
    writeJsonFile(path, DEFAULT_POLICY);
    console.log(`wrote ${path}`);
    return;
  }

  if (subcommand === "trust") {
    const recipient = required(firstPositional(rest), "recipient");
    const policy = loadPolicy(policyPath);
    if (!policy.trustedRecipients.includes(recipient)) {
      policy.trustedRecipients.push(recipient);
      policy.trustedRecipients.sort();
      writeJsonFile(policyPath, policy);
    }
    printPolicyMutation("trusted recipient", recipient, policyPath, policy, options.json);
    return;
  }

  if (subcommand === "untrust") {
    const recipient = required(firstPositional(rest), "recipient");
    const policy = loadPolicy(policyPath);
    policy.trustedRecipients = policy.trustedRecipients.filter((item) => item !== recipient);
    writeJsonFile(policyPath, policy);
    printPolicyMutation("removed trusted recipient", recipient, policyPath, policy, options.json);
    return;
  }

  if (subcommand === "set") {
    const values = positionals(rest);
    const field = values[0];
    const rawValue = values[1];
    const policy = loadPolicy(policyPath);
    setPolicyField(policy, field, rawValue);
    writeJsonFile(policyPath, policy);
    printPolicyMutation("set policy field", `${field}=${rawValue}`, policyPath, policy, options.json);
    return;
  }

  throw new Error("policy command must be show, init, trust, untrust, or set");
}

async function runIntent(args) {
  const [subcommand, ...rest] = args;
  const options = parseOptions(rest);
  const config = loadConfig(options.config);
  const effectiveOptions = mergeConfigOptions(options, config);

  if (subcommand === "list") {
    const limit = Number(options.limit ?? 20);
    const intents = listIntents(effectiveOptions.store).slice(0, limit);
    if (options.json) {
      console.log(JSON.stringify(intents, null, 2));
    } else {
      for (const intent of intents) {
        console.log(`${intent.intentId}\t${intent.decision}\t${intent.settlement.amount} ${intent.settlement.token}`);
      }
    }
    return;
  }

  if (subcommand === "show") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    if (options.json) {
      console.log(JSON.stringify(intent, null, 2));
    } else {
      printIntent(intent, false);
    }
    return;
  }

  if (subcommand === "status") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const status = intentStatus(intent);
    if (options.json) {
      console.log(JSON.stringify(status, null, 2));
    } else {
      printIntentStatus(status);
    }
    return;
  }

  if (subcommand === "preflight") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const baseUrl = (effectiveOptions.reviewBaseUrl ?? DEFAULT_CONFIG.reviewBaseUrl).replace(/\/+$/, "");
    const preflight = transactionRequestPreflight(intent, baseUrl);
    if (options.json) {
      console.log(JSON.stringify(preflight, null, 2));
    } else {
      printTransactionRequestPreflight(preflight);
    }
    return;
  }

  if (subcommand === "receipt") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const receipt = intentReceipt(intent);
    if (options.json) {
      console.log(JSON.stringify(receipt, null, 2));
    } else {
      printIntentReceipt(receipt);
    }
    return;
  }

  if (subcommand === "events") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const events = intentEvents(intent);
    if (options.json) {
      console.log(JSON.stringify(events, null, 2));
    } else {
      printIntentEvents(events);
    }
    return;
  }

  if (subcommand === "approve" || subcommand === "reject") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const updated = applyReviewDecision(intent, {
      decision: subcommand === "approve" ? "approved" : "rejected",
      reviewer: options.reviewer,
      reason: options.reason,
    });
    saveIntent(updated, effectiveOptions.store);

    if (options.json) {
      console.log(JSON.stringify(intentStatus(updated), null, 2));
    } else {
      printIntentStatus(intentStatus(updated));
    }
    return;
  }

  if (subcommand === "execute") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    const intent = loadIntent(required(intentId, "intent_id"), effectiveOptions.store);
    const result = await executeIntent(intent, effectiveOptions);
    saveIntent(result.intent, effectiveOptions.store);

    if (options.json) {
      console.log(JSON.stringify(result.output, null, 2));
    } else {
      printExecutionResult(result.output);
    }
    return;
  }

  if (subcommand === "export") {
    const [intentId] = rest.filter((item) => !item.startsWith("--"));
    printReviewExport(required(intentId, "intent_id"), effectiveOptions, options);
    return;
  }

  throw new Error("intent command must be list, show, status, preflight, receipt, events, approve, reject, execute, or export");
}

function runReview(args) {
  const options = parseOptions(args);
  const config = loadConfig(options.config);
  const effectiveOptions = mergeConfigOptions(options, config);
  const intentId = required(firstPositional(args), "intent_id");
  printReviewExport(intentId, effectiveOptions, options);
}

function runDoctor(args) {
  const options = parseOptions(args);
  const configPath = options.config ?? "jup.config.json";
  const configFound = existsSync(configPath);
  const config = configFound ? loadConfig(options.config) : { ...cloneConfig(DEFAULT_CONFIG), loaded: false };
  const effectiveOptions = mergeConfigOptions(options, config);
  const policyPath = effectiveOptions.policy ?? config.policyPath ?? DEFAULT_CONFIG.policyPath;
  const policyFound = existsSync(policyPath);
  const policy = loadPolicy(policyFound ? policyPath : undefined);
  const intentStore = effectiveOptions.store ?? DEFAULT_CONFIG.intentStore;
  const intentStoreFound = existsSync(intentStore);
  const intentCount = listIntents(intentStore).length;
  const warnings = [];

  if (!configFound) {
    warnings.push("jup.config.json not found; run jup-sh init");
  }
  if (!policyFound) {
    warnings.push(`${policyPath} not found; default policy is being used`);
  }
  if (policy.maxAutoSettleUSDC > policy.maxAllowedSettleUSDC) {
    warnings.push("maxAutoSettleUSDC is greater than maxAllowedSettleUSDC");
  }

  const result = {
    status: warnings.length === 0 ? "ok" : "warning",
    cliVersion: PACKAGE_JSON.version,
    packageName: PACKAGE_JSON.name,
    config: {
      path: configPath,
      found: configFound,
    },
    policy: {
      path: policyPath,
      found: policyFound,
      maxAutoSettleUSDC: policy.maxAutoSettleUSDC,
      maxAllowedSettleUSDC: policy.maxAllowedSettleUSDC,
      maxPriceImpactBps: policy.maxPriceImpactBps,
      trustedRecipients: policy.trustedRecipients,
      verifiedTokens: policy.verifiedTokens,
      reviewUnknownRecipients: policy.reviewUnknownRecipients,
    },
    intentStore: {
      path: intentStore,
      found: intentStoreFound,
      count: intentCount,
    },
    reviewBaseUrl: effectiveOptions.reviewBaseUrl ?? DEFAULT_CONFIG.reviewBaseUrl,
    quoteProvider: effectiveOptions.quoteProvider ?? DEFAULT_CONFIG.quoteProvider,
    warnings,
  };

  if (options.json) {
    console.log(JSON.stringify(result, null, 2));
  } else {
    printDoctor(result);
  }
}

function printReviewExport(intentId, effectiveOptions, options) {
  const intent = loadIntent(intentId, effectiveOptions.store);
  const baseUrl = (effectiveOptions.reviewBaseUrl ?? DEFAULT_CONFIG.reviewBaseUrl).replace(/\/+$/, "");
  const payload = encodeReviewPayload(intent);
  const reviewUrl = buildFullReviewUrl(intent, baseUrl);

  if (options.payloadOnly) {
    console.log(payload);
    return;
  }

  if (options.json) {
    console.log(
      JSON.stringify(
        {
          intentId: intent.intentId,
          decision: intent.decision,
          nextAction: intent.nextAction,
          reviewUrl,
          reviewCommand: buildReviewCommand(intent.intentId),
          payload,
        },
        null,
        2
      )
    );
    return;
  }

  console.log(reviewUrl);
}

function withReviewHandoff(intent, reviewBaseUrl) {
  if (intent.nextAction !== "open_review") return intent;

  return {
    ...intent,
    reviewUrl: buildFullReviewUrl(intent, reviewBaseUrl),
    reviewCommand: buildReviewCommand(intent.intentId),
  };
}

function buildFullReviewUrl(intent, reviewBaseUrl) {
  const baseUrl = reviewBaseUrl.replace(/\/+$/, "");
  return `${baseUrl}/pay/${intent.intentId}#intent=${encodeReviewPayload(intent)}`;
}

function encodeReviewPayload(intent) {
  return Buffer.from(JSON.stringify(intent), "utf8").toString("base64url");
}

function buildReviewCommand(intentId) {
  return `npx ${PACKAGE_JSON.name} review ${intentId}`;
}

function parseOptions(args) {
  const options = {};

  for (let index = 0; index < args.length; index += 1) {
    const item = args[index];
    if (!item.startsWith("--")) continue;

    const key = toCamelCase(item.slice(2));
    const next = args[index + 1];

    if (!next || next.startsWith("--")) {
      options[key] = true;
    } else if (key === "settle") {
      const values = [next];
      if (args[index + 2] && !args[index + 2].startsWith("--")) {
        values.push(args[index + 2]);
        index += 1;
      }
      options[key] = values;
      index += 1;
    } else {
      options[key] = next;
      index += 1;
    }
  }

  return options;
}

function positionals(args) {
  const values = [];
  for (let index = 0; index < args.length; index += 1) {
    const item = args[index];
    if (item.startsWith("--")) {
      const next = args[index + 1];
      if (next && !next.startsWith("--")) index += 1;
      continue;
    }
    values.push(item);
  }
  return values;
}

function firstPositional(args) {
  return positionals(args)[0];
}

function parseSettlement(options) {
  const settle = Array.isArray(options.settle) ? options.settle : [];

  if (options.amount !== undefined) {
    if (settle.length !== 1) {
      throw new Error("use --amount <amount> --settle <token>");
    }
    return {
      settleAmount: positiveAmount(Number(options.amount), "amount"),
      settleToken: settle[0],
    };
  }

  if (settle.length === 2) {
    return {
      settleAmount: positiveAmount(Number(settle[0]), "settle amount"),
      settleToken: settle[1],
    };
  }

  throw new Error("settlement must be provided as --amount <amount> --settle <token>");
}

function loadPolicy(path) {
  const defaultPath = "jup.policy.json";
  const effectivePath = path ?? (existsSync(defaultPath) ? defaultPath : null);
  if (!effectivePath) return clonePolicy(DEFAULT_POLICY);

  return {
    ...clonePolicy(DEFAULT_POLICY),
    ...JSON.parse(readFileSync(effectivePath, "utf8")),
  };
}

function loadConfig(path) {
  const defaultPath = "jup.config.json";
  const effectivePath = path ?? (existsSync(defaultPath) ? defaultPath : null);
  if (!effectivePath) return { ...cloneConfig(DEFAULT_CONFIG), loaded: false };

  return {
    ...cloneConfig(DEFAULT_CONFIG),
    ...JSON.parse(readFileSync(effectivePath, "utf8")),
    loaded: true,
  };
}

function cloneConfig(config) {
  return { ...config };
}

function mergeConfigOptions(options, config) {
  return {
    ...options,
    policy: options.policy ?? (config.loaded ? config.policyPath : undefined),
    store: options.store ?? config.intentStore,
    reviewBaseUrl: options.reviewBaseUrl ?? config.reviewBaseUrl,
    quoteProvider: options.quoteProvider ?? config.quoteProvider,
    intentTtlMinutes: options.intentTtlMinutes ?? config.intentTtlMinutes,
    quoteTtlMinutes: options.quoteTtlMinutes ?? config.quoteTtlMinutes,
    rpcUrl: options.rpcUrl ?? config.rpcUrl ?? process.env.SOLANA_RPC_URL ?? "https://api.mainnet-beta.solana.com",
    jupiterSwapUrl: options.jupiterSwapUrl ?? config.jupiterSwapUrl ?? process.env.JUPITER_SWAP_URL ?? "https://api.jup.ag/swap/v1/swap",
    jupiterApiKey: options.jupiterApiKey ?? config.jupiterApiKey ?? process.env.JUPITER_API_KEY,
  };
}

function assertWritable(path, force) {
  if (existsSync(path) && !force) {
    throw new Error(`${path} already exists; pass --force to overwrite`);
  }
}

function writeJsonFile(path, value) {
  writeFileSync(path, `${JSON.stringify(value, null, 2)}\n`);
}

function resolvePath(path) {
  if (path.startsWith("~")) {
    return resolve(process.env.HOME || ".", path.slice(1));
  }
  return resolve(path);
}

function setPolicyField(policy, field, rawValue) {
  const normalizedField = normalizePolicyField(required(field, "policy field"));
  if (rawValue === undefined) {
    throw new Error("policy value is required");
  }

  if (normalizedField === "maxAutoSettleUSDC") {
    policy.maxAutoSettleUSDC = positiveAmount(Number(rawValue), "max auto amount");
    return;
  }
  if (normalizedField === "maxAllowedSettleUSDC") {
    policy.maxAllowedSettleUSDC = positiveAmount(Number(rawValue), "max allowed amount");
    return;
  }
  if (normalizedField === "maxPriceImpactBps") {
    policy.maxPriceImpactBps = nonNegativeInteger(Number(rawValue), "max price impact bps");
    return;
  }
  if (normalizedField === "reviewHighPriceImpact") {
    policy.reviewHighPriceImpact = parseBoolean(rawValue, "review high price impact");
    return;
  }
  if (normalizedField === "reviewUnknownRecipients") {
    policy.reviewUnknownRecipients = parseBoolean(rawValue, "review unknown recipients");
    return;
  }

  throw new Error(`unsupported policy field: ${field}`);
}

function normalizePolicyField(field) {
  const fields = new Map([
    ["max-auto", "maxAutoSettleUSDC"],
    ["max-auto-settle", "maxAutoSettleUSDC"],
    ["maxAutoSettleUSDC", "maxAutoSettleUSDC"],
    ["max-allowed", "maxAllowedSettleUSDC"],
    ["max-allowed-settle", "maxAllowedSettleUSDC"],
    ["maxAllowedSettleUSDC", "maxAllowedSettleUSDC"],
    ["max-price-impact", "maxPriceImpactBps"],
    ["max-price-impact-bps", "maxPriceImpactBps"],
    ["maxPriceImpactBps", "maxPriceImpactBps"],
    ["review-high-price-impact", "reviewHighPriceImpact"],
    ["reviewHighPriceImpact", "reviewHighPriceImpact"],
    ["review-unknown-recipients", "reviewUnknownRecipients"],
    ["reviewUnknownRecipients", "reviewUnknownRecipients"],
  ]);
  return fields.get(field) ?? field;
}

function parseBoolean(value, field) {
  if (value === "true") return true;
  if (value === "false") return false;
  throw new Error(`${field} must be true or false`);
}

function nonNegativeInteger(value, field) {
  if (!Number.isInteger(value) || value < 0) {
    throw new Error(`${field} must be a non-negative integer`);
  }
  return value;
}

function printPolicyMutation(action, value, path, policy, json) {
  if (json) {
    console.log(JSON.stringify({ action, value, path, policy }, null, 2));
    return;
  }
  console.log(`${action}: ${value}`);
  console.log(`updated ${path}`);
}

function clonePolicy(policy) {
  return {
    ...policy,
    verifiedTokens: [...policy.verifiedTokens],
    trustedRecipients: [...policy.trustedRecipients],
  };
}

function evaluatePolicy(input, policy) {
  const verifiedTokens = new Set(policy.verifiedTokens.map(normalizeToken));
  const trustedRecipients = new Set(policy.trustedRecipients);
  const checks = [];

  checks.push(
    verifiedTokens.has(input.payToken)
      ? policyCheck("verified_token", "pass", `${input.payToken} is verified`)
      : policyCheck("verified_token", "reject", `${input.payToken} is not a verified token`)
  );
  checks.push(
    input.settleToken === "USDC"
      ? policyCheck("settlement_token", "pass", "USDC settlement is supported")
      : policyCheck("settlement_token", "reject", "only USDC settlement is supported in Phase 1")
  );
  checks.push(
    input.settleAmount <= policy.maxAllowedSettleUSDC
      ? policyCheck(
          "max_allowed_amount",
          "pass",
          `${trimNumber(input.settleAmount)} USDC is within the max allowed limit`
        )
      : policyCheck(
          "max_allowed_amount",
          "reject",
          `settlement amount exceeds ${trimNumber(policy.maxAllowedSettleUSDC)} USDC`
        )
  );
  checks.push(
    !policy.reviewUnknownRecipients
      ? policyCheck("recipient_trust", "pass", "unknown recipients do not require review")
      : input.recipient && trustedRecipients.has(input.recipient)
        ? policyCheck("recipient_trust", "pass", "recipient is trusted")
        : policyCheck("recipient_trust", "review", "recipient is not trusted")
  );
  checks.push(
    input.settleAmount <= policy.maxAutoSettleUSDC
      ? policyCheck(
          "auto_pay_limit",
          "pass",
          `${trimNumber(input.settleAmount)} USDC is within the auto-pay limit`
        )
      : policyCheck(
          "auto_pay_limit",
          "review",
          `settlement amount exceeds auto-pay limit of ${trimNumber(policy.maxAutoSettleUSDC)} USDC`
        )
  );

  return policyResultFromChecks(checks);
}

async function quoteSettlement(input, options) {
  if ((options.quoteProvider ?? "mock") === "jupiter") {
    return quoteJupiter(input, options);
  }
  return quoteMock(input);
}

function quoteMock(input) {
  const price = MOCK_PRICES_USDC[input.payToken];
  if (!price || price <= 0) {
    throw new Error(`no mock quote price for token ${input.payToken}`);
  }

  return {
    source: "mock_jupiter",
    inputToken: input.payToken,
    inputAmount: round(input.settleAmount / price, 9),
    settleAmount: input.settleAmount,
    settleToken: input.settleToken,
    priceImpactBps: 12,
  };
}

async function quoteJupiter(input, options) {
  const inputToken = TOKENS[input.payToken];
  const settleToken = TOKENS[input.settleToken];

  if (!inputToken) throw new Error(`Jupiter quote token is not configured: ${input.payToken}`);
  if (!settleToken) throw new Error(`Jupiter quote token is not configured: ${input.settleToken}`);

  const url = new URL(options.jupiterQuoteUrl ?? "https://api.jup.ag/swap/v1/quote");
  url.searchParams.set("inputMint", inputToken.mint);
  url.searchParams.set("outputMint", settleToken.mint);
  url.searchParams.set("amount", String(Math.round(input.settleAmount * 10 ** settleToken.decimals)));
  url.searchParams.set("slippageBps", String(options.slippageBps ?? 50));
  url.searchParams.set("swapMode", "ExactOut");

  const apiKey = options.jupiterApiKey ?? process.env.JUPITER_API_KEY;
  const response = await fetch(url, {
    headers: apiKey ? { "x-api-key": apiKey } : undefined,
  });

  if (!response.ok) {
    throw new Error(`Jupiter quote failed: ${response.status} ${response.statusText}`);
  }

  const quote = await response.json();
  return {
    source: "jupiter_swap_exact_out",
    inputToken: input.payToken,
    inputAmount: Number(quote.inAmount) / 10 ** inputToken.decimals,
    settleAmount: Number(quote.outAmount) / 10 ** settleToken.decimals,
    settleToken: input.settleToken,
    priceImpactBps: Math.round(Math.abs(Number(quote.priceImpactPct)) * 10_000),
    rawQuoteResponse: quote,
  };
}

function evaluateQuotePolicy(quote, policy) {
  return [
    policyCheck("quote_available", "pass", `${quote.source} quote is available`),
    quote.settleToken === "USDC"
      ? policyCheck("quote_settlement_token", "pass", "quote settles to USDC")
      : policyCheck("quote_settlement_token", "reject", "quote does not settle to USDC"),
    quote.priceImpactBps <= policy.maxPriceImpactBps
      ? policyCheck(
          "quote_price_impact",
          "pass",
          `quote price impact is ${quote.priceImpactBps} bps, within the ${policy.maxPriceImpactBps} bps policy limit`
        )
      : policyCheck(
          "quote_price_impact",
          policy.reviewHighPriceImpact ? "review" : "pass",
          `quote price impact is ${quote.priceImpactBps} bps, above the ${policy.maxPriceImpactBps} bps policy limit`
        ),
  ];
}

function policyResultFromChecks(checks) {
  const reasons = checks
    .filter((check) => check.status === "review" || check.status === "reject")
    .map((check) => check.message);
  const hasReject = checks.some((check) => check.status === "reject");
  const hasReview = checks.some((check) => check.status === "review");

  if (hasReject) {
    return { decision: "rejected", nextAction: "rejected", riskLevel: "high", reasons, checks };
  }
  if (hasReview) {
    return {
      decision: "review_required",
      nextAction: "open_review",
      riskLevel: "medium",
      reasons,
      checks,
    };
  }
  return {
    decision: "auto_pay",
    nextAction: "ready_for_authorization",
    riskLevel: "low",
    reasons,
    checks,
  };
}

function saveIntent(intent, store) {
  const dir = resolve(store ?? join(".jup-sh", "intents"));
  mkdirSync(dir, { recursive: true });
  writeFileSync(join(dir, `${intent.intentId}.json`), `${JSON.stringify(intent, null, 2)}\n`);
}

function loadIntent(intentId, store) {
  const dir = resolve(store ?? join(".jup-sh", "intents"));
  return JSON.parse(readFileSync(join(dir, `${intentId}.json`), "utf8"));
}

function listIntents(store) {
  const dir = resolve(store ?? join(".jup-sh", "intents"));
  if (!existsSync(dir)) return [];

  return readdirSync(dir)
    .filter((file) => file.endsWith(".json"))
    .map((file) => JSON.parse(readFileSync(join(dir, file), "utf8")))
    .sort((a, b) => b.createdAt.localeCompare(a.createdAt));
}

function intentStatus(intent) {
  return {
    intentId: intent.intentId,
    status: intent.status,
    decision: intent.decision,
    nextAction: intent.nextAction,
    riskLevel: intent.riskLevel,
    reviewUrl: intent.reviewUrl,
    reviewCommand: intent.reviewCommand,
    reviewDecision: intent.reviewDecision ?? null,
    eventCount: Array.isArray(intent.events) ? intent.events.length : 0,
    quoteExpiresAt: intent.quote?.expiresAt ?? null,
    quoteExpired: isQuoteExpired(intent),
    createdAt: intent.createdAt,
    expiresAt: intent.expiresAt ?? null,
    expired: isIntentExpired(intent),
  };
}

function intentEvents(intent) {
  return {
    intentId: intent.intentId,
    events: Array.isArray(intent.events) ? intent.events : [],
  };
}

function intentReceipt(intent) {
  if (intent.receipt) {
    return {
      intentId: intent.intentId,
      available: true,
      status: intent.receipt.status ?? "available",
      transactionImplemented: true,
      receipt: intent.receipt,
    };
  }

  return {
    intentId: intent.intentId,
    available: false,
    status: "not_available",
    transactionImplemented: false,
    reason: "No confirmed settlement has been observed for this intent.",
    receipt: null,
  };
}

function appendIntentEvent(intent, event) {
  return {
    ...intent,
    events: [
      ...(Array.isArray(intent.events) ? intent.events : []),
      {
        at: event.at ?? new Date().toISOString(),
        ...event,
      },
    ],
  };
}

function applyReviewDecision(intent, input) {
  if (isIntentExpired(intent)) {
    throw new Error("intent is expired");
  }

  if (intent.status !== "review_required" || intent.nextAction !== "open_review") {
    throw new Error("intent is not waiting for review");
  }

  const decision = normalizeReviewDecision(input.decision);
  const reviewedAt = new Date().toISOString();

  const updated = {
    ...intent,
    status: decision === "approved" ? "ready_for_authorization" : "rejected",
    nextAction: decision === "approved" ? "ready_for_authorization" : "rejected",
    reviewDecision: {
      decision,
      reviewer:
        typeof input.reviewer === "string" && input.reviewer.trim()
          ? input.reviewer.trim()
          : "local",
      reason:
        typeof input.reason === "string" && input.reason.trim()
          ? input.reason.trim()
          : null,
      reviewedAt,
    },
    updatedAt: reviewedAt,
  };

  return appendIntentEvent(updated, {
    type: decision === "approved" ? "review.approved" : "review.rejected",
    at: reviewedAt,
    reviewer:
      typeof input.reviewer === "string" && input.reviewer.trim()
        ? input.reviewer.trim()
        : "local",
    reason:
      typeof input.reason === "string" && input.reason.trim()
        ? input.reason.trim()
        : null,
  });
}

async function executeIntent(intent, options) {
  const gate = transactionRequestErrorForIntent(intent);
  if (gate) {
    throw new Error(gate.message);
  }

  const executionGate = transactionRequestExecutionErrorForIntent(intent);
  if (executionGate) {
    throw new Error(executionGate.message);
  }

  const keypairPath = required(options.keypair, "keypair");
  const web3 = require("@solana/web3.js");
  const payer = loadSolanaKeypair(web3, keypairPath);
  const account = payer.publicKey.toBase58();
  const existingAccount = intent.transactionRequest?.account;
  if (existingAccount && existingAccount !== account) {
    throw new Error("transaction request is already bound to a different account");
  }

  const accountBoundAt = intent.transactionRequest?.accountBoundAt ?? new Date().toISOString();
  let updated = {
    ...intent,
    transactionRequest: {
      ...(intent.transactionRequest ?? {}),
      account,
      accountBoundAt,
    },
    updatedAt: accountBoundAt,
  };
  if (!existingAccount) {
    updated = appendIntentEvent(updated, {
      type: "transaction_request.account_bound",
      at: accountBoundAt,
      account: previewAccount(account),
    });
  }

  let swap;
  try {
    swap = await buildJupiterSwapTransaction(intent, account, options);
  } catch (error) {
    const failed = appendIntentEvent(updated, {
      type: "execution.failed",
      reason: error.message,
    });
    return {
      intent: {
        ...failed,
        transactionRequest: {
          ...(failed.transactionRequest ?? {}),
          status: "transaction_failed",
          transactionSource: "jupiter_swap",
        },
        updatedAt: new Date().toISOString(),
      },
      output: {
        intentId: intent.intentId,
        status: "failed",
        error: "jupiter_swap_failed",
        message: error.message,
      },
    };
  }

  const transaction = web3.VersionedTransaction.deserialize(Buffer.from(swap.transaction, "base64"));
  transaction.sign([payer]);
  const signedTransaction = Buffer.from(transaction.serialize()).toString("base64");
  const dryRun = options.dryRun === true || options.dryRun === "true";

  if (dryRun) {
    const now = new Date().toISOString();
    const dryRunIntent = appendIntentEvent(
      {
        ...updated,
        transactionRequest: {
          ...(updated.transactionRequest ?? {}),
          status: "signed_dry_run",
          transactionSource: "jupiter_swap",
          transactionCreatedAt: now,
        },
        updatedAt: now,
      },
      {
        type: "execution.signed_dry_run",
        at: now,
        account: previewAccount(account),
        source: "jupiter_swap",
      }
    );

    return {
      intent: dryRunIntent,
      output: {
        intentId: intent.intentId,
        status: "signed_dry_run",
        account,
        transaction: signedTransaction,
      },
    };
  }

  const connection = new web3.Connection(options.rpcUrl, options.commitment ?? "confirmed");
  const signature = await connection.sendRawTransaction(transaction.serialize(), {
    skipPreflight: options.skipPreflight === true || options.skipPreflight === "true",
    maxRetries: Number(options.maxRetries ?? 3),
  });
  const confirmation = await waitForSignatureConfirmation(
    connection,
    signature,
    Number(options.confirmTimeoutMs ?? 60_000)
  );
  const confirmedAt = new Date().toISOString();
  const receipt = {
    status: confirmation.err ? "failed" : "confirmed",
    signature,
    account,
    rpcUrl: options.rpcUrl,
    explorerUrl: `https://solscan.io/tx/${signature}`,
    confirmedAt,
    confirmation,
  };
  const settled = receipt.status === "confirmed";
  const executedIntent = appendIntentEvent(
    {
      ...updated,
      status: settled ? "settled" : "execution_failed",
      nextAction: settled ? "settled" : "retry_authorization",
      receipt,
      transactionRequest: {
        ...(updated.transactionRequest ?? {}),
        status: receipt.status,
        transactionSource: "jupiter_swap",
        transactionCreatedAt: confirmedAt,
      },
      updatedAt: confirmedAt,
    },
    {
      type: settled ? "execution.confirmed" : "execution.failed",
      at: confirmedAt,
      account: previewAccount(account),
      signature,
    }
  );

  return {
    intent: executedIntent,
    output: {
      intentId: intent.intentId,
      status: receipt.status,
      signature,
      explorerUrl: receipt.explorerUrl,
      receipt,
    },
  };
}

function loadSolanaKeypair(web3, keypairPath) {
  const decoded = JSON.parse(readFileSync(resolvePath(keypairPath), "utf8"));
  const secretKey = Array.isArray(decoded) ? decoded : decoded.secretKey;
  if (!Array.isArray(secretKey)) {
    throw new Error("keypair must be a Solana JSON keypair array or an object with secretKey");
  }
  return web3.Keypair.fromSecretKey(Uint8Array.from(secretKey));
}

async function buildJupiterSwapTransaction(intent, account, options) {
  const response = await fetch(options.jupiterSwapUrl, {
    method: "POST",
    headers: {
      "content-type": "application/json",
      ...(options.jupiterApiKey ? { "x-api-key": options.jupiterApiKey } : {}),
    },
    body: JSON.stringify({
      quoteResponse: intent.quote.rawQuoteResponse,
      userPublicKey: account,
      destinationTokenAccount: intent.recipientTokenAccount,
    }),
  });
  const text = await response.text();
  let body = null;
  if (text.trim()) {
    try {
      body = JSON.parse(text);
    } catch {
      body = { raw: text };
    }
  }

  if (!response.ok) {
    throw new Error(body?.error || body?.message || `Jupiter swap failed: ${response.status} ${response.statusText}`);
  }
  if (typeof body?.swapTransaction !== "string" || body.swapTransaction.length === 0) {
    throw new Error("Jupiter swap response did not include swapTransaction");
  }
  return {
    transaction: body.swapTransaction,
  };
}

async function waitForSignatureConfirmation(connection, signature, timeoutMs) {
  const startedAt = Date.now();
  let lastStatus = null;
  while (Date.now() - startedAt <= timeoutMs) {
    const result = await connection.getSignatureStatuses([signature], {
      searchTransactionHistory: true,
    });
    const status = result.value[0];
    if (status) {
      lastStatus = status;
      if (status.err || status.confirmationStatus === "confirmed" || status.confirmationStatus === "finalized") {
        return status;
      }
    }
    await new Promise((resolve) => setTimeout(resolve, 1000));
  }

  throw new Error(`timed out waiting for confirmation for ${signature}`);
}

function normalizeReviewDecision(value) {
  if (value === "approved" || value === "rejected") return value;
  throw new Error("review decision must be approved or rejected");
}

function transactionRequestErrorForIntent(intent) {
  if (isIntentExpired(intent)) {
    return {
      error: "intent_expired",
      message: "Expired intents cannot create transaction requests.",
    };
  }

  if (intent.status === "review_required" || intent.nextAction === "open_review") {
    return {
      error: "review_required",
      message: "Intent must be approved before transaction creation.",
    };
  }

  if (intent.status === "rejected" || intent.nextAction === "rejected") {
    return {
      error: "intent_rejected",
      message: "Rejected intents cannot create transaction requests.",
    };
  }

  if (intent.status !== "ready_for_authorization" || intent.nextAction !== "ready_for_authorization") {
    return {
      error: "intent_not_ready",
      message: "Intent is not ready for authorization.",
    };
  }

  if (isQuoteExpired(intent)) {
    return {
      error: "quote_expired",
      message: "Quote is expired and must be refreshed before transaction creation.",
    };
  }

  return null;
}

function transactionRequestExecutionErrorForIntent(intent) {
  if (!intent.quote || typeof intent.quote.rawQuoteResponse !== "object" || intent.quote.rawQuoteResponse === null) {
    return {
      error: "quote_not_executable",
      message: "Intent must be created with a Jupiter executable quote before transaction creation.",
    };
  }

  if (!isSolanaPublicKey(intent.recipientTokenAccount)) {
    return {
      error: "missing_recipient_token_account",
      message: "Intent must include a recipient token account before transaction creation.",
    };
  }

  return null;
}

function statusForTransactionGate(gate) {
  if (gate.error === "review_required") return "blocked_by_review";
  if (gate.error === "intent_rejected") return "blocked_rejected";
  if (gate.error === "quote_expired") return "blocked_quote_expired";
  if (gate.error === "quote_not_executable") return "blocked_quote_not_executable";
  if (gate.error === "missing_recipient_token_account") return "blocked_missing_recipient_token_account";
  return "blocked_not_ready";
}

function isSolanaPublicKey(value) {
  return typeof value === "string" && /^[1-9A-HJ-NP-Za-km-z]{32,44}$/.test(value);
}

function previewAccount(account) {
  if (typeof account !== "string" || account.length <= 8) return account;
  return `${account.slice(0, 4)}...${account.slice(-4)}`;
}

function isIntentExpired(intent, now = new Date()) {
  return typeof intent.expiresAt === "string" && Date.parse(intent.expiresAt) <= now.getTime();
}

function isQuoteExpired(intent, now = new Date()) {
  return typeof intent.quote?.expiresAt === "string" && Date.parse(intent.quote.expiresAt) <= now.getTime();
}

function expiresAtFor(createdAt, ttlMinutes) {
  const ttl = Number(ttlMinutes ?? DEFAULT_CONFIG.intentTtlMinutes);
  const safeTtl = Number.isFinite(ttl) && ttl > 0 ? ttl : DEFAULT_CONFIG.intentTtlMinutes;
  return new Date(createdAt.getTime() + safeTtl * 60_000);
}

function transactionRequestPreflight(intent, baseUrl) {
  const endpointUrl = new URL(`${baseUrl.replace(/\/+$/, "")}/api/transaction-requests/${intent.intentId}`);
  if (intent.transactionRequest?.requestToken) {
    endpointUrl.searchParams.set("request", intent.transactionRequest.requestToken);
  }
  const endpoint = endpointUrl.toString();
  const base = {
    intentId: intent.intentId,
    kind: "solana_pay_transaction_request",
    endpoint,
    url: `solana:${endpoint}`,
    method: "GET_POST",
    transactionImplemented: true,
    boundAccount: intent.transactionRequest?.account ?? null,
    accountBoundAt: intent.transactionRequest?.accountBoundAt ?? null,
  };
  const gate = transactionRequestErrorForIntent(intent);

  if (gate) {
    return {
      ...base,
      status: statusForTransactionGate(gate),
      canRequestTransaction: false,
      reason: gate.message,
    };
  }

  const executionGate = transactionRequestExecutionErrorForIntent(intent);
  if (executionGate) {
    return {
      ...base,
      status: statusForTransactionGate(executionGate),
      canRequestTransaction: false,
      reason: executionGate.message,
    };
  }

  return {
    ...base,
    status: "ready",
    canRequestTransaction: true,
    reason: "Ready to create and execute a Jupiter swap transaction.",
  };
}

function printDoctor(result) {
  console.log("jup.sh doctor");
  console.log("");
  console.log(`CLI version: ${result.cliVersion}`);
  console.log(`Config: ${result.config.found ? "found" : "missing"} ${result.config.path}`);
  console.log(`Policy: ${result.policy.found ? "found" : "missing"} ${result.policy.path}`);
  console.log(`Intent store: ${result.intentStore.path} (${result.intentStore.count} intents)`);
  console.log(`Review URL: ${result.reviewBaseUrl}`);
  console.log(`Quote provider: ${result.quoteProvider}`);
  console.log(
    `Trusted recipients: ${
      result.policy.trustedRecipients.length ? result.policy.trustedRecipients.join(", ") : "(none)"
    }`
  );
  if (result.warnings.length > 0) {
    console.log("");
    console.log("Warnings:");
    for (const warning of result.warnings) {
      console.log(`- ${warning}`);
    }
  }
  console.log("");
  console.log(`Status: ${result.status}`);
}

function printIntentStatus(status) {
  console.log(`Intent: ${status.intentId}`);
  console.log(`Status: ${status.status}`);
  console.log(`Decision: ${status.decision}`);
  console.log(`Next action: ${status.nextAction}`);
  console.log(`Risk: ${status.riskLevel}`);
  if (status.reviewDecision) {
    console.log(`Review decision: ${status.reviewDecision.decision}`);
  }
  console.log(`Review: ${status.reviewUrl}`);
}

function printTransactionRequestPreflight(preflight) {
  console.log(`Intent: ${preflight.intentId}`);
  console.log(`Transaction request: ${preflight.status}`);
  console.log(`Implemented: ${preflight.transactionImplemented}`);
  console.log(`Can request transaction: ${preflight.canRequestTransaction}`);
  console.log(`Endpoint: ${preflight.endpoint}`);
  console.log(`Reason: ${preflight.reason}`);
}

function printIntentReceipt(receipt) {
  console.log(`Intent: ${receipt.intentId}`);
  console.log(`Receipt: ${receipt.status}`);
  console.log(`Available: ${receipt.available}`);
  console.log(`Transaction implemented: ${receipt.transactionImplemented}`);
  if (receipt.reason) {
    console.log(`Reason: ${receipt.reason}`);
  }
}

function printExecutionResult(result) {
  console.log(`Intent: ${result.intentId}`);
  console.log(`Status: ${result.status}`);
  if (result.signature) {
    console.log(`Signature: ${result.signature}`);
  }
  if (result.explorerUrl) {
    console.log(`Explorer: ${result.explorerUrl}`);
  }
  if (result.error) {
    console.log(`Error: ${result.error}`);
    console.log(`Message: ${result.message}`);
  }
}

function printIntentEvents(result) {
  console.log(`Intent: ${result.intentId}`);
  if (result.events.length === 0) {
    console.log("Events: (none)");
    return;
  }

  for (const event of result.events) {
    console.log(`${event.at}\t${event.type}`);
  }
}

function printPolicy(policy) {
  console.log("jup.sh policy");
  console.log(`Max auto-pay amount: ${trimNumber(policy.maxAutoSettleUSDC)} USDC`);
  console.log(`Max allowed amount: ${trimNumber(policy.maxAllowedSettleUSDC)} USDC`);
  console.log(`Max price impact: ${policy.maxPriceImpactBps} bps`);
  console.log(`Review high price impact: ${policy.reviewHighPriceImpact}`);
  console.log(`Verified tokens: ${policy.verifiedTokens.join(", ")}`);
  console.log(
    `Trusted recipients: ${
      policy.trustedRecipients.length ? policy.trustedRecipients.join(", ") : "(none)"
    }`
  );
  console.log(`Review unknown recipients: ${policy.reviewUnknownRecipients}`);
}

function printIntent(intent, json) {
  if (json) {
    console.log(JSON.stringify(intent, null, 2));
    return;
  }

  console.log(`Intent: ${intent.intentId}`);
  console.log(`Decision: ${intent.decision}`);
  console.log(`Next action: ${intent.nextAction}`);
  console.log(`Agent: ${intent.agent}`);
  console.log(`Pay token: ${intent.payToken}`);
  console.log(`Settlement: ${trimNumber(intent.settlement.amount)} ${intent.settlement.token}`);
  console.log(`Review: ${intent.reviewUrl}`);
}

