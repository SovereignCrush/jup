  console.log("  doctor [--json]");
}

function exitCodeForDecision(decision) {
  if (decision === "auto_pay") return 0;
  if (decision === "review_required") return 2;
  return 1;
}

function statusForDecision(decision) {
  if (decision === "auto_pay") return "ready_for_authorization";
  if (decision === "review_required") return "review_required";
  return "rejected";
}

function policyCheck(name, status, message) {
  return { name, status, message };
}

function hasFlag(args, name) {
  return args.includes(`--${name}`);
}

function required(value, field) {
  if (typeof value !== "string" || value.trim() === "") {
    throw new Error(`${field} is required`);
  }
  return value.trim();
}

function positiveAmount(value, field) {
  if (!Number.isFinite(value) || value <= 0) {
    throw new Error(`${field} must be a positive number`);
  }
  return value;
}

function normalizeToken(value) {
  return required(value, "token").toUpperCase();
}

function toCamelCase(value) {
  return value.replace(/-([a-z])/g, (_, letter) => letter.toUpperCase());
}

function trimNumber(value) {
  return Number.isInteger(value) ? String(value) : String(value);
}

function round(value, decimals) {
  const factor = 10 ** decimals;
  return Math.round(value * factor) / factor;
}
